# Port for the Express server (Approach 1 — Bun/Express only)
PORT=3000

# Discord webhook URL to send notifications to
# How to get it: Server Settings > Integrations > Webhooks > New Webhook > Copy Webhook URL
DISCORD_WEBHOOK_URL=

# Secret used to validate that incoming requests are genuinely from GitHub (HMAC-SHA256)
# Must match the secret set in your GitHub repository webhook settings
# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=
